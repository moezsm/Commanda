# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
# New Supabase projects expose this key name:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Backward compatibility (optional if publishable key is set):
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Postgres — used by the auto-migration runner at build time.
# Get from Supabase Dashboard > Project Settings > Database > Connection string > URI
# !! Use the DIRECT (non-pooler) connection string so DDL works !!
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# App URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — add when billing is ready (iteration 07+)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
